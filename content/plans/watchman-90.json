        "husbands_post":  { "ref": "Ephesians 5:22-33", "note": "Love her as Christ loved the church." },
        "fathers_charge": { "ref": "Deuteronomy 6:1-9", "note": "Teach them diligently to your children." },
        "citizens_stand": { "ref": "Romans 12", "note": "Be not conformed to this world." },
        "evening_peace":  { "ref": "Psalm 1", "note": "Blessed is the man who walks not in the counsel of the wicked." }
      }
    },
    { "day": 2, "reflection_prompt": "Where did you compromise today? Where did you hold the line?",
      "readings": {
        "morning_wisdom": { "ref": "Proverbs 2", "note": "Seek her as silver, search for her as hidden treasure." },
        "husbands_post":  { "ref": "1 Peter 3:7", "note": "Live with your wife in an understanding way." },
        "fathers_charge": { "ref": "Deuteronomy 4:9", "note": "Keep your soul diligently; make them known to your children." },
        "citizens_stand": { "ref": "Romans 13:1-7", "note": "Be subject to the governing authorities." },
        "evening_peace":  { "ref": "Psalm 23", "note": "The LORD is my shepherd." }
