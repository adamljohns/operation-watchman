        "husbands_post":  { "ref": "Colossians 3:18-19", "note": "Husbands, love your wives and do not be harsh with them." },
        "fathers_charge": { "ref": "Psalm 78:1-8", "note": "Tell the next generation the glorious deeds of the LORD." },
        "citizens_stand": { "ref": "1 Peter 2:13-17", "note": "Be subject for the Lord's sake to every human institution." },
        "evening_peace":  { "ref": "Psalm 46", "note": "Be still and know that I am God." }
